# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Which AI provider the report-generation layer uses. Currently only "claude" is implemented.
AI_PROVIDER=claude

# Anthropic API key (console.anthropic.com) — server-side only, never exposed to the browser.
ANTHROPIC_API_KEY=

# Supabase project settings (supabase.com project settings > API).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
