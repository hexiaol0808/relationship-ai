# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Which AI provider the report-generation layer uses: "claude" or "openai".
AI_PROVIDER=openai

# Anthropic API key (console.anthropic.com) — server-side only, never exposed to the browser.
ANTHROPIC_API_KEY=

# OpenAI API key (platform.openai.com) — server-side only, never exposed to the browser.
OPENAI_API_KEY=

# Supabase project settings (supabase.com project settings > API).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
